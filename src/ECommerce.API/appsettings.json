{
	"ConnectionStrings": {
		"DefaultConnection": "Host=db;Database=database;Username=postgres;Password=YOUR_DB_PASSWORD"
	},
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft": "Warning",
			"Microsoft.Hosting.Lifetime": "Information"
		}
	},
	"Jwt": {
		"SecretKey": "PLACEHOLDER_JWT_SECRET_KEY",
		"Issuer": "ECommerce.API",
		"Audience": "ECommerce.Client",
		"AccessTokenExpirationMinutes": 60
	},
	"MoMo": {
		"BaseUrl": "https://test-payment.momo.vn",
		"PartnerCode": "PLACEHOLDER_MOMO_PARTNER_CODE",
		"AccessKey": "PLACEHOLDER_MOMO_ACCESS_KEY",
		"SecretKey": "PLACEHOLDER_MOMO_SECRET_KEY",
		"RedirectUrl": "http://localhost:3000/payment-result",
		"IpnUrl": "http://localhost:8080/api/payments/momo/ipn",
		"RequestType": "captureWallet"
	},
	"ZaloPay": {
		"AppId": "${ZaloPay__AppId}",
		"Key1": "${ZaloPay__Key1}",
		"Key2": "${ZaloPay__Key2}",
		"CreateOrderUrl": "${ZaloPay__CreateOrderUrl}",
		"CallbackUrl": "${ZaloPay__CallbackUrl}",
		"BankCode": "${ZaloPay__BankCode}"
	},
	"EmailSettings": {
		"Provider": "SendGrid",
		"ApiKey": "",
		"FromName": "Sanquo Shop",
		"FromAddress": "no-reply@em8750.sanquo.shop"
	},
	"AllowedHosts": "*"
}
