{
	"ConnectionStrings": {
		"DefaultConnection": ""
	},
	"Loki": {
		"Url": ""
	},
	"Serilog": {
		"MinimumLevel": {
			"Default": "Information",
			"Override": {
				"Microsoft": "Warning",
				"Microsoft.Hosting.Lifetime": "Information",
				"Microsoft.EntityFrameworkCore": "Warning"
			}
		},
		"WriteTo": [
			{
				"Name": "Console",
				"Args": {
					"outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
				}
			}
		],
		"Enrich": [
			"FromLogContext"
		],
		"Properties": {
			"Application": "ECommerce.API"
		}
	},
	"Jwt": {
		"SecretKey": "",
		"Issuer": "ECommerce.API",
		"Audience": "ECommerce.Client",
		"AccessTokenExpirationMinutes": 60
	},
	"RabbitMQ": {
		"Host": "",
		"User": "",
		"Password": "",
		"VirtualHost": "",
		"Port": 5672
	},
	"ZaloPay": {
		"AppId": "",
		"Key1": "",
		"Key2": "",
		"CreateOrderUrl": "",
		"CallbackUrl": "",
		"BankCode": ""
	},
	"EmailSettings": {
		"Provider": "SendGrid",
		"ApiKey": "",
		"FromName": "Sanquo Shop",
		"FromAddress": "no-reply@em8750.sanquo.shop"
	},
	"AllowedHosts": "*"
}