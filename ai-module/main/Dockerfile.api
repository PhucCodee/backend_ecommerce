FROM python:3.11-slim

WORKDIR /app

# Install dependencies
# The requirements file lives alongside this Dockerfile
COPY ai-module/main/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r ./requirements.txt

# Copy code
COPY . .

# Run FastAPI
CMD ["uvicorn", "api:api", "--host", "0.0.0.0", "--port", "8000"]